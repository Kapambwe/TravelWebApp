@page "/"
@inject NavigationManager Navigation

<HeroSearch />

<div class="page-section">
    <RadzenText TextStyle="TextStyle.H4" Style="font-weight:700;margin-bottom:16px;">Your recent searches</RadzenText>
    <div style="display:flex; gap:16px; overflow-x:auto; padding-bottom:12px;">
        <RadzenCard Style="min-width:260px; padding:16px; border-radius:12px; cursor:pointer;" @onclick="@(() => Navigation.NavigateTo("/search?q=Cape Town"))">
            <div style="display:flex; gap:12px; align-items:center;">
                <div style="width:50px; height:50px; border-radius:8px; background-image:url('images/capetown.jpg'); background-size:cover;"></div>
                <div>
                    <div style="font-weight:700;">Cape Town</div>
                    <div style="font-size:0.75rem; color:var(--text-secondary);">11 Jun - 15 Jun, 2 guests</div>
                </div>
            </div>
        </RadzenCard>
        <RadzenCard Style="min-width:260px; padding:16px; border-radius:12px; cursor:pointer;" @onclick="@(() => Navigation.NavigateTo("/search?q=Kruger"))">
            <div style="display:flex; gap:12px; align-items:center;">
                <div style="width:50px; height:50px; border-radius:8px; background-image:url('images/kruger.jpg'); background-size:cover;"></div>
                <div>
                    <div style="font-weight:700;">Kruger Park</div>
                    <div style="font-size:0.75rem; color:var(--text-secondary);">22 Jul - 28 Jul, 4 guests</div>
                </div>
            </div>
        </RadzenCard>
    </div>
</div>

<div class="testimonials-section">
    <div class="section-header" style="text-align:center;">
        <RadzenText TextStyle="TextStyle.H4">What Our Travellers Say</RadzenText>
        <RadzenText TextStyle="TextStyle.Body2" Style="color:#5A5A7A">Real experiences from real adventurers</RadzenText>
    </div>
    
    <RadzenCarousel AutoPlay="true" Interval="5000" Style="height:280px;margin-top:40px;">
        <Items>
            @foreach (var t in _testimonials)
            {
                <RadzenCarouselItem>
                    <div style="max-width:700px;margin:0 auto;text-align:center;padding:20px;">
                        <div style="font-size:3rem;color:var(--accent);margin-bottom:16px;">&ldquo;</div>
                        <RadzenText TextStyle="TextStyle.H5" Style="font-style:italic;line-height:1.6;font-weight:500;">@t.Text</RadzenText>
                        <div style="margin-top:24px;">
                            <RadzenText TextStyle="TextStyle.Body1" Style="font-weight:700;">@t.Author</RadzenText>
                            <RadzenText TextStyle="TextStyle.Caption" Style="color:#5A5A7A;">@t.Location</RadzenText>
                        </div>
                    </div>
                </RadzenCarouselItem>
            }
        </Items>
    </RadzenCarousel>
</div>

<style>
    .home-page { min-height: 100vh; }
    .testimonials-section { padding: 80px 24px; background: white; }
</style>

@code {
    private List<Testimonial> _testimonials = [
        new() { Author = "Sarah M.", Location = "United Kingdom", Text = "Our safari in Kruger was life-changing. Everything was perfectly organized by TravelSA." },
        new() { Author = "David L.", Location = "South Africa", Text = "The best booking platform for African travel. Simple, secure, and the AI assistant Otto is brilliant!" },
        new() { Author = "Elena P.", Location = "Germany", Text = "Victoria Falls was breathtaking. The package we booked included everything we needed for a stress-free trip." }
    ];

    private class Testimonial
    {
        public string Author { get; set; } = "";
        public string Location { get; set; } = "";
        public string Text { get; set; } = "";
    }
}
