@using TravelWebApp.Models

<RadzenCard Style="padding:24px;border-radius:16px;">
    <div style="font-size:2.5rem;margin-bottom:16px;">@Service.Icon</div>
    <RadzenText TextStyle="TextStyle.H6">@(string.IsNullOrEmpty(Service.Title) ? Service.Name : Service.Title)</RadzenText>
    <RadzenText TextStyle="TextStyle.Body2" Style="color:var(--text-secondary);margin:8px 0 20px;">@Service.Description</RadzenText>
    <RadzenButton Text="Learn More" ButtonStyle="ButtonStyle.Light" Variant="Variant.Outlined" Style="width:100%;" />
</RadzenCard>

@code {
    [Parameter] public dynamic Service { get; set; }
}

